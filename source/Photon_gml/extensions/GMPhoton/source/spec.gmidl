    property is_visible : gmval { get; set; }
    [field, type_hint = `bool?`]
    property is_open : gmval { get; set; }
    [field, type_hint = `string?`]
    property lobby_name : gmval { get; set; }
    [field, type_hint = `PhotonRealtimeLobbyType?`]
    property lobby_type : gmval { get; set; }
    [field, type_hint = `real?`]
    property player_ttl : gmval { get; set; }
    [field, type_hint = `real?`]
    property empty_room_ttl : gmval { get; set; }
    [field, type_hint = `bool?`]
    property suppress_room_events : gmval { get; set; }
    [field, type_hint = `bool?`]
    property publish_user_id : gmval { get; set; }
    [field, type_hint = `string[]`]
    property lobby_keys : gmval { get; set; }
    [field, type_hint = `string[]`]
    property expected_users : gmval { get; set; }
}

[global]
class `[[PhotonRealtimeJoinRoomOptions]]` prototype Object
{
    [field, type_hint = `bool?`]
    property rejoin : gmval { get; set; }
    [field, type_hint = `real?`]
    property cache_slice_index : gmval { get; set; }
}

[global]
class `[[PhotonRealtimeRaiseEventOptions]]` prototype Object
{
    [field, type_hint = `PhotonRealtimeReceiverGroup?`]
    property receiver_group : gmval { get; set; }
    [field, type_hint = `int32?`]
    property interest_group : gmval { get; set; }
    [field, type_hint = `PhotonRealtimeEventCache?`]
    property event_cache : gmval { get; set; }
    [field, type_hint = `int32?`]
    property channel_id : gmval { get; set; }
    [field, type_hint = `int32?`]
    property cache_slice_index : gmval { get; set; }
    [field, type_hint = `bool?`]
    property encrypt : gmval { get; set; }
    /// Target specific player numbers. Empty array broadcasts to receiver_group (default: Others).
    [field, type_hint = `int32[]`]
    property target_players : gmval { get; set; }
}

[global]
class `[[PhotonRealtimeAuthenticationValues]]` prototype Object
{
    /// Unique identifier for this player. Used by Photon for matchmaking and friend lookup.
    [field, type_hint = `string?`]
    property user_id : gmval { get; set; }
    /// Authentication provider. Defaults to PhotonRealtimeCustomAuthType.None.
    [field, type_hint = `PhotonRealtimeCustomAuthType?`]
    property auth_type : gmval { get; set; }
    /// Token/parameters string passed to the authentication provider.
    [field, type_hint = `string?`]
    property parameters : gmval { get; set; }
}

[global]
class `[[PhotonRealtimeConnectOptions]]` prototype Object
{
    [field, type_hint = `PhotonRealtimeAuthenticationValues?`]
    property authentication_values : gmval { get; set; }
    /// Display name visible to other players. Separate from user_id in authentication_values.
    [field, type_hint = `string?`]
    property username : gmval { get; set; }
    /// Override the Photon name server address. Leave unset to use the default cloud.
    [field, type_hint = `string?`]
    property server_address : gmval { get; set; }
    [field, type_hint = `bool?`]
    property try_use_datagram_encryption : gmval { get; set; }
    [field, type_hint = `bool?`]
    property use_background_thread : gmval { get; set; }
}

[global]
class `[[PhotonChatConnectOptions]]` prototype Object
{
    [field, type_hint = `PhotonRealtimeAuthenticationValues?`]
    property authentication_values : gmval { get; set; }
    /// Override the Photon name server address. Leave unset to use the default cloud.
    [field, type_hint = `string?`]
    property server_address : gmval { get; set; }
    [field, type_hint = `bool?`]
    property use_background_thread : gmval { get; set; }
}

/// Friend info entry delivered by photon_realtime_set_callback_find_friends_response.
/// arg0 — array of [[PhotonRealtimeFriendInfo]]
[global]
class `[[PhotonRealtimeFriendInfo]]` prototype Object
{
    [field] property user_id    : string { get; set; }
    [field] property is_online  : bool   { get; set; }
    [field] property room       : string { get; set; }
    [field] property is_in_room : bool   { get; set; }
}

/// Snapshot of a single room in the lobby browser list.
/// The photon_realtime_set_callback_get_room_list_response callback receives two arrays:
///   arg0 — array of [[PhotonRealtimeRoomInfo]] (rooms added/updated)
///   arg1 — array of string (room names that were removed)
[global]
class `[[PhotonRealtimeRoomInfo]]` prototype Object
{
    [field] property name : string { get; set; }
    [field] property player_count : int32 { get; set; }
    [field] property max_players : int32 { get; set; }
    [field] property is_open : bool { get; set; }
    /// Custom room properties exposed to the lobby, as a GML struct.
    [field] property custom_properties : object { get; set; }
}

/// Lobby statistics entry delivered by onLobbyStatsResponse / onLobbyStatsUpdate.
[global]
class `[[PhotonRealtimeLobbyStats]]` prototype Object
{
    [field] property name : string { get; set; }
    [field] property type : int32 { get; set; }
    [field] property peer_count : int32 { get; set; }
    [field] property room_count : int32 { get; set; }
}

/// A single chat channel message delivered by onGetMessages.
[global]
class `[[PhotonChatMessage]]` prototype Object
{
    [field] property sender : string { get; set; }
    [field] property content : string { get; set; }
}

/// Result of a single channel subscribe attempt delivered by subscribeReturn.
[global]
class `[[PhotonChatSubscribeResult]]` prototype Object
{
    [field] property channel_name : string { get; set; }
    [field] property success : bool { get; set; }
}

