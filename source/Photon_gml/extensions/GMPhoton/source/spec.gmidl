[gml_api]
module GMPhoton;

// -----------------------------------------------------------------------------
// Structs
// -----------------------------------------------------------------------------

[global]
class `[[PhotonRealtimeEventBufferReceived]]` prototype Object
{
    [field] property ok : bool { get; set; }
    [field] property player_number : int32 { get; set; }
    [field] property event_code : int32 { get; set; }
    [field] property bytes_written : uint32 { get; set; }
}

[global]
class `[[PhotonRealtimeJoinRandomOptions]]` prototype Object
{
    [field, type_hint = `real?`]
    property max_players : gmval { get; set; }
    [field, type_hint = `PhotonRealtimeMatchmakingMode?`]
    property matchmaking_mode : gmval { get; set; }
    [field, type_hint = `string?`]
    property lobby_name : gmval { get; set; }
    [field, type_hint = `PhotonRealtimeLobbyType?`]
    property lobby_type : gmval { get; set; }
    [field, type_hint = `string?`]
    property sql_filter : gmval { get; set; }
    [field, type_hint = `string[]`]
    property expected_users : gmval { get; set; }
}

[global]
class `[[PhotonRealtimeRoomOptions]]` prototype Object
{
    [field, type_hint = `real?`]
    property max_players : gmval { get; set; }
