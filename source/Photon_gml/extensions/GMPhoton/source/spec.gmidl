function photon_realtime_operation_leave_lobby([type_hint=`func?`]callback: gmval): bool;

[global, bind = typed_gml]
function photon_realtime_operation_create_room(room_name: string, [type_hint = `PhotonRealtimeRoomOptions`] options, custom_properties: object, [type_hint=`func?`]callback: gmval): bool;

[global, bind = typed_gml]
function photon_realtime_operation_join_or_create_room(room_name: string, [type_hint = `PhotonRealtimeRoomOptions`] options, custom_properties: object, [type_hint=`int32?`] cache_slice_index: gmval, [type_hint=`func?`]callback: gmval): bool;

[global, bind = typed_gml]
function photon_realtime_operation_join_room(room_name: string, [type_hint = `PhotonRealtimeJoinRoomOptions`] options, [type_hint=`func?`]callback: gmval): bool;

[global, bind = typed_gml]
function photon_realtime_operation_join_random_room([type_hint = `PhotonRealtimeJoinRandomOptions`] options, expected_properties: object, [type_hint=`func?`]callback: gmval): bool;

[global, bind = typed_gml]
function photon_realtime_operation_leave_room(will_come_back: bool, send_authentication_cookie: bool, [type_hint=`func?`]callback: gmval): bool;

/// Try to join a random room matching random_options/expected_properties; if none found,
/// create a room named room_name with options/custom_properties.
/// Fires the same callback as photon_realtime_operation_join_or_create_room.
[global, bind = typed_gml]
function photon_realtime_operation_join_random_or_create_room(room_name: string, [type_hint = `PhotonRealtimeRoomOptions`] options, custom_properties: object, [type_hint = `PhotonRealtimeJoinRandomOptions`] random_options, expected_properties: object, [type_hint=`func?`]callback: gmval): bool;

/// Request a room list from a specific SQL lobby. Fires the callback with (rooms[], removed[]).
[global, bind = typed_gml]
function photon_realtime_operation_get_room_list(lobby_name: string, sql_filter: string, [type_hint=`func?`]callback: gmval): bool;

/// Request lobby stats for all tracked lobbies. Fires the callback with (stats[]).
[global, bind = typed_gml]
function photon_realtime_operation_lobby_stats([type_hint=`func?`]callback: gmval): bool;

/// Find friends by user ID array. Fires the callback with (friends[]).
[global, bind = typed_gml]
function photon_realtime_operation_find_friends([type_hint=`string[]`] friends: gmval, [type_hint=`func?`]callback: gmval): bool;

/// Send an HTTP WebRPC to the server.
/// Callback: (error_code, error_string, uri_path, result_code, response_data_struct).
[global, bind = typed_gml]
function photon_realtime_operation_web_rpc(uri_path: string, [type_hint=`func?`]callback: gmval): bool;

/// Change the interest groups this client receives events from.
/// Pass empty arrays to remove/add nothing.
[global, bind = typed_gml]
function photon_realtime_operation_change_groups(
    [type_hint = `int32[]?`] groups_to_remove: gmval,
    [type_hint = `int32[]?`] groups_to_add: gmval
): bool;

/// Send additional data for a multi-step custom authentication flow. Call from inside photon_realtime_set_callback_custom_authentication_step.
[global, bind = typed_gml]
function photon_realtime_operation_custom_auth_next_step([type_hint = `PhotonRealtimeAuthenticationValues`] authentication: gmval): bool;

