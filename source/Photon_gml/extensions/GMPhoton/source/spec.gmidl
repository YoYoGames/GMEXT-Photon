// =============================================================================
// PhotonVoice-cpp — Speaking threshold
// =============================================================================

/// Returns the silence timeout in milliseconds used by the speaking-detection
/// system. A remote voice is considered speaking if a PCM frame arrived within
/// this window. Default: 200 ms.
[global, bind = typed_gml]
function photon_voice_get_speaking_threshold_ms(): int32;

/// Sets the silence timeout in milliseconds for speaking detection.
/// Lower values make speaking-end detection more responsive but more sensitive
/// to network jitter. Raise it if players flicker between speaking/silent.
[global, bind = typed_gml]
function photon_voice_set_speaking_threshold_ms(ms: int32): bool;

