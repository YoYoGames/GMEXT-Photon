{
  "$schema": "./extgen.schema.json",
  "input": "spec.gmidl",
  "root": "./",
  "gamemaker": {
    "wrappers": {
      "outputFile": "../../../scripts/GMMobileUtilsMicrophone_API/GMMobileUtilsMicrophone_API.gml"
    },
    "extension": {
      "mode": "patch",
      "outputFile": "../../../extensions/GMMobileUtilsMicrophone/GMMobileUtilsMicrophone.yy",
      "patchFrameworks": true
    }
  },
  "targets": {
    "ios":{
      "mode": "objc"
    },
    "android": {
      "mode": "java"
    }
  },
  "extras": {
    "docs": { 
      "outputFile": "../../../../../docs/extgen_docs_microphone.js"
    }
  }
}